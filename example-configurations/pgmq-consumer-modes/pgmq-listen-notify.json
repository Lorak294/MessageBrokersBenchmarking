{
  "producersCount": 1,
  "consumerGroups": [3],
  "communicationMode": "PointToPoint",
  "messagesPerConsumerGroup": [10000],
  "messageSizeInBytes": 1024,
  "sendFrequencyMps": 1000,
  "mqConfig": {
